# Telegram Bot Configuration
# Ottieni il token da: https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Supabase Configuration
# Ottieni le credenziali da: https://supabase.co
# SUPABASE_URL è l'URL del progetto (es. https://xxxxx.supabase.co)
# SUPABASE_KEY è la Service Role Key (SECRET - non condividere!)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-secret-key-here

# Game Configuration
# Punteggio obiettivo di default per le nuove partite
TARGET_SCORE=2000
